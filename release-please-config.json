{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "include-component-in-tag": false,
  "always-update": true,
  "packages": {
    "apps/sample-api": {
      "component": "sample-api",
      "package-name": "sample-api",
      "extra-files": [
        {
          "type": "yaml",
          "path": "/charts/sample-api/Chart.yaml",
          "jsonpath": "$.appVersion"
        },
        {
          "type": "yaml",
          "path": "/charts/sample-api/values-prod.yaml",
          "jsonpath": "$.image.tag"
        }
      ]
    },
    "apps/sample-worker": {
      "component": "sample-worker",
      "package-name": "sample-worker",
      "extra-files": [
        {
          "type": "yaml",
          "path": "/charts/sample-worker/Chart.yaml",
          "jsonpath": "$.appVersion"
        },
        {
          "type": "yaml",
          "path": "/charts/sample-worker/values-prod.yaml",
          "jsonpath": "$.image.tag"
        }
      ]
    }
  }
}
